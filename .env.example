# Copy this file to .env and adjust values for your environment.
# Use .env.qa for QA and .env.prod for production.
TARGET_ENV=qa
BASE_URL_QA=https://api.freecrm.com
BASE_URL_PROD=https://api.freecrm.com

# CRM / Postman collection variables
# Set these when running the CRM CRUD flows. Example:
# CRM_EMAIL=deep.patel@simformsolutions.com
# CRM_PASSWORD=Dpatel@1
# TOKEN is populated at runtime after successful login; do not hardcode in shared files.
CRM_BASE_URL=https://api.freecrm.com/api/1
CRM_AUTH_URL=https://api.freecrm.com/api/1/auth
CRM_EMAIL=deep.patel@simformsolutions.com
CRM_PASSWORD=Dpatel@1
TOKEN=

